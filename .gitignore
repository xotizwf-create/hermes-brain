# Secrets must never enter this repository.
# Canonical knowledge = files in git. Real secret values = server only (/root/.hermes/secure).

# Secret value files / scratch
secrets.yaml
access-map.yaml
agent-secrets/
# Local-only secret links/notes (e.g. the Vault URL with its token) — never commit
*.local.txt
*.secret.*
*.secrets.*
*.vault.*
*.key
*.pem
.env
.env.*
# Google OAuth / service-account material (server-only)
token.json
*client_secret*.json
*oauth*token*.json
google_service_account*.json

# OS / tooling noise
.DS_Store
Thumbs.db
__pycache__/
*.pyc
.venv/
node_modules/
tmp_*
tmp/

# Ad-hoc task leftovers — one-off scripts/outputs live ONLY in tmp/, never the repo root
_*_tmp.*
.tmp_*
_nspd_*
_weekly_*
/*.xlsx

# Local Google AI Studio mockup, not part of the brain
/Интерфейс для Агента/

# Owner-provided source material, integrated into the Albery repo (wb-cabinet/) — not brain content
/Страница WB кабинет/
/Интерфейс для Агента/

# graphify knowledge graph output (generated, rebuildable via `graphify update .`)
graphify-out/
